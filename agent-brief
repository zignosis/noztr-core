#!/usr/bin/env bash
set -u -o pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -f "${script_dir}/AGENTS.md" ]]; then
    repo_root="${script_dir}"
else
    repo_root="$(cd "${script_dir}/.." && pwd)"
fi

now_utc="$(date -u +"%Y-%m-%d %H:%M:%SZ")"

is_git_repo="no"
if [[ -d "${repo_root}/.git" ]]; then
    is_git_repo="yes"
fi

zig_version="not found"
if command -v zig >/dev/null 2>&1; then
    zig_version="$(zig version 2>/dev/null || true)"
    if [[ -z "${zig_version}" ]]; then
        zig_version="available (version lookup failed)"
    fi
fi

zig_file_count=0
if [[ -d "${repo_root}/src" ]]; then
    shopt -s globstar nullglob
    zig_files=("${repo_root}"/src/**/*.zig)
    zig_file_count="${#zig_files[@]}"
    shopt -u globstar nullglob
fi

report_file() {
    local rel="$1"
    if [[ -f "${repo_root}/${rel}" ]]; then
        printf -- '- [x] `%s`\n' "${rel}"
    else
        printf -- '- [ ] `%s`\n' "${rel}"
    fi
}

missing_artifacts=()
collect_missing() {
    local rel="$1"
    if [[ ! -f "${repo_root}/${rel}" ]]; then
        missing_artifacts+=("${rel}")
    fi
}

startup_docs=(
    "AGENTS.md"
    "handoff.md"
    ".private-docs/README.md"
    ".private-docs/plans/build-plan.md"
    ".private-docs/plans/decision-index.md"
    ".private-docs/plans/phase-h-remaining-work.md"
    ".private-docs/plans/phase-h-rc-api-freeze.md"
)

on_demand_docs=(
    ".private-docs/guides/IMPLEMENTATION_QUALITY_GATE.md"
    ".private-docs/guides/TIGER_STYLE.md"
    ".private-docs/guides/NOZTR_STYLE.md"
    ".private-docs/guides/zig-patterns.md"
    ".private-docs/guides/zig-anti-patterns.md"
    ".private-docs/guides/docs-style_guide.md"
    ".private-docs/plans/decision-log.md"
    ".private-docs/plans/noztr-sdk-ownership-matrix.md"
    ".private-docs/plans/packet-template.md"
)

for rel in "${startup_docs[@]}"; do
    collect_missing "${rel}"
done
for rel in "${on_demand_docs[@]}"; do
    collect_missing "${rel}"
done

printf "# Agent Brief\n\n"
printf "Routing-first startup snapshot for AI agents.\n\n"
printf "_Generated:_ %s\n\n" "${now_utc}"

printf "## Repository\n\n"
printf -- '- root: `%s`\n' "${repo_root}"
printf -- '- git repo: `%s`\n' "${is_git_repo}"
printf -- '- zig: `%s`\n' "${zig_version}"
printf -- '- src zig files: `%s`\n\n' "${zig_file_count}"

printf "## Read Now\n\n"
for rel in "${startup_docs[@]}"; do
    report_file "${rel}"
done
printf "\n"

printf "## Load On Demand\n\n"
printf -- '- `.private-docs/guides/IMPLEMENTATION_QUALITY_GATE.md` when starting or closing an implementation, audit, or robustness slice\n'
printf -- '- `.private-docs/guides/TIGER_STYLE.md` and `.private-docs/guides/NOZTR_STYLE.md` for Zig implementation or API work\n'
printf -- '- `.private-docs/guides/zig-patterns.md` and `.private-docs/guides/zig-anti-patterns.md` for Zig implementation or review\n'
printf -- '- `.private-docs/guides/docs-style_guide.md` for public docs, contributor docs, or internal docs-surface work\n'
printf -- '- `.private-docs/plans/decision-log.md` when a task cites a specific decision ID or changes policy defaults\n'
printf -- '- `.private-docs/plans/noztr-sdk-ownership-matrix.md` for kernel-vs-SDK ownership questions\n'
printf -- '- `.private-docs/plans/packet-template.md` when creating or repairing packet docs\n'
printf -- '- completed packets and reports in `.private-docs/plans/` or `.private-docs/research/` only when the current task needs that exact evidence\n'
printf -- '- relevant NIP-specific docs, tests, and source files for the current task\n\n'

printf "## Current Active Lanes\n\n"
printf -- '- active Phase H packet: `.private-docs/plans/phase-h-remaining-work.md`\n'
printf -- '- active RC review packet: `.private-docs/plans/phase-h-rc-api-freeze.md`\n'
printf -- '- local RC review result: `.private-docs/research/rc-api-freeze-review-report.md`\n\n'

printf "## Next Missing Artifacts\n\n"
if [[ "${#missing_artifacts[@]}" -eq 0 ]]; then
    printf -- "- none\n\n"
else
    for rel in "${missing_artifacts[@]}"; do
        printf -- '- `%s`\n' "${rel}"
    done
    printf "\n"
fi

printf "## Canonical Commands\n\n"
printf '```bash\n'
printf "zig build test --summary all\n"
printf "zig build\n"
printf '```\n'
